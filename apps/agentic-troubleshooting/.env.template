# ==============================================================================
# MOCK MODE — set to "false" once real credentials are available
# ==============================================================================
MOCK_MODE="true"

# ==============================================================================
# ACTIVE CHAT PLATFORM: "slack" | "gchat"
# ==============================================================================
CHAT_PLATFORM="slack"

# ==============================================================================
# INFRASTRUCTURE & CLUSTER CONFIG
# ==============================================================================
CLUSTER_NAME="your-eks-cluster"
AWS_REGION="us-east-2"
BEDROCK_MODEL_ID="amazon.nova-micro-v1:0"
LOG_LEVEL="INFO"
LOG_FORMAT="json"

# ==============================================================================
# SLACK CONFIGURATION (Primary)
# Get these from https://api.slack.com/apps → your app
# ==============================================================================
SLACK_BOT_TOKEN="xoxb-your-bot-token"
SLACK_APP_TOKEN="xapp-your-app-token"
SLACK_SIGNING_SECRET="your-signing-secret"

# Chat Behavior
RESPONSE_THRESHOLD="0.7"
MAX_CONTEXT_MESSAGES="10"
RESPONSE_DELAY_SECONDS="0"
ENABLE_THREAD_CONTEXT="true"

# ==============================================================================
# GOOGLE CHAT (Set CHAT_PLATFORM="gchat" to activate)
# ==============================================================================
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account-key.json"
# GCHAT_PROJECT_ID="your-gcp-project-id"
# GCHAT_PROJECT_NUMBER="your-gcp-project-number"

# ==============================================================================
# AGENT SETTINGS
# ==============================================================================
AGENT_NAME="strands-chatops-agent"
AGENT_DESCRIPTION="An Agentic AI workflow for real-time EKS cluster discovery and troubleshooting."

# ==============================================================================
# KUBERNETES & MCP
# ==============================================================================
ENABLE_EKS_MCP="true"

# ==============================================================================
# MEMORY AGENT (A2A)
# ==============================================================================
MEMORY_AGENT_SERVER_URL="http://127.0.0.1:9000"
VECTOR_BUCKET=""
INDEX_NAME=""

# ==============================================================================
# LANGFUSE OBSERVABILITY (Optional)
# ==============================================================================
# ENABLE_LANGFUSE="false"
# LANGFUSE_SECRET_KEY=""
# LANGFUSE_PUBLIC_KEY=""
# LANGFUSE_HOST="http://localhost:3000"
